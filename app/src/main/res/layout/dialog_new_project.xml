<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etProjectTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Project title (min 3 characters)"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etProjectDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="What are you building?"
        android:minLines="3"
        android:gravity="top"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etProjectTechStack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tech stack needed (e.g. Kotlin, Firebase)"/>

</LinearLayout>